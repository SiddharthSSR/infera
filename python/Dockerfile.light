# Infera Worker - Lightweight (Mock Engine)
# Use this for testing without vLLM
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip install --upgrade pip

# Copy worker source code
COPY pyproject.toml .
COPY src/ ./src/

# Install the worker package (without vLLM)
RUN pip install --no-cache-dir .

# Environment variables
ENV INFERA_ENGINE=mock
ENV INFERA_HTTP_PORT=8081
ENV INFERA_LOG_LEVEL=INFO

# Expose ports
EXPOSE 8081

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8081/health || exit 1

# Run the worker
CMD ["python", "-m", "infera_worker.cli"]