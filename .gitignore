# ============================================================================
# Infera .gitignore
# ============================================================================

# ============================================================================
# Go
# ============================================================================
bin/
*.exe
*.dll
*.so
*.dylib
*.test
/go/gateway
/go/*.test
go.work
go/vendor/

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
python/venv/
python/.venv/
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
python/.python-version

# ============================================================================
# Frontend (Node.js / React)
# ============================================================================
frontend/node_modules/
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
*.tsbuildinfo

# ============================================================================
# IDEs and Editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# OS Generated
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# Environment and Secrets
# ============================================================================
.env
.env.local
.env.*.local
secrets/
.secrets/
*.pem
*.key

# ============================================================================
# Logs and Databases
# ============================================================================
*.log
logs/
*.sqlite
*.db
*.db-wal
*.db-shm

# ============================================================================
# Proto Generated Files
# ============================================================================
go/pkg/proto/
python/src/infera_proto/

# ============================================================================
# Misc
# ============================================================================
tmp/
temp/
coverage/
TODOs/
