# Required
RUNPOD_API_KEY=
INFERA_GATEWAY_ADDRESS=https://your-domain.com
INFERA_ALLOWED_ORIGINS=https://your-frontend-domain.com
INFERA_WORKER_SHARED_TOKEN=
INFERA_RELEASE_ID=v1.3.0
INFERA_WORKER_PROTOCOL_VERSION=1
INFERA_GATEWAY_IMAGE=docker.io/codingtensor/infera-gateway:v1.3.0
INFERA_GATEWAY_REPLICAS=1
INFERA_AUDIT_LEDGER_BACKEND=sqlite
# Required for the postgres backend. Use TLS and a managed PostgreSQL service
# in production; a shared-filesystem SQLite database is not replica-safe.
INFERA_AUDIT_LEDGER_DSN=
# Generate with: openssl rand -base64 32
INFERA_PROVIDER_CREDENTIAL_ENCRYPTION_KEY=

# Auto-generated on first run if empty
INFERA_ADMIN_KEY=

# Optional
VASTAI_API_KEY=
HF_TOKEN=
INFERA_WORKER_IMAGE=docker.io/codingtensor/worker-vllm:engine-phase2
INFERA_WORKER_IMAGE_VLLM=docker.io/codingtensor/worker-vllm:engine-phase2
INFERA_WORKER_IMAGE_SGLANG=docker.io/codingtensor/worker-sglang:engine-phase2
INFERA_WORKER_IMAGE_TENSORRT_LLM=docker.io/codingtensor/worker-tensorrt-llm:engine-phase2
INFERA_ENABLE_BATCHING=true
INFERA_MAX_BATCH_SIZE=8
INFERA_MAX_BATCH_WAIT_MS=50
INFERA_AFFINITY_TTL_SECONDS=600
INFERA_RATE_LIMIT_REQUESTS_PER_MINUTE=60
INFERA_RATE_LIMIT_BURST_SIZE=10
INFERA_MAX_IN_FLIGHT_REQUESTS=100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
ALERT_EMAIL_TO=alerts@your-domain.com
ALERT_SMTP_FROM=alerts@your-domain.com
ALERT_SMTP_SMARTHOST=smtp.gmail.com:587
ALERT_SMTP_USERNAME=alerts@your-domain.com
ALERT_SMTP_PASSWORD=
