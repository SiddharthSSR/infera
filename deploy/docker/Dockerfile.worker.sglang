# Infera Worker - SGLang Production Image for RunPod
#
# This image mirrors the worker runtime conventions used by the vLLM image
# while isolating SGLang-specific dependencies into a dedicated build target.

FROM --platform=linux/amd64 runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

WORKDIR /app

# Install system dependencies needed by the worker runtime and health checks.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    libnuma1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip

ARG SGLANG_PACKAGE=sglang

# Install a conservative SGLang runtime plus the common tokenizer / HTTP stack
# expected by the worker implementation.
RUN pip install --no-cache-dir \
    "${SGLANG_PACKAGE}" \
    "transformers>=4.43.0" \
    "accelerate>=0.30.0" \
    "tokenizers>=0.19.0" \
    "aiohttp>=3.9.0"

COPY python/pyproject.toml .
COPY python/README.md .
COPY python/src/ ./src/

# Install the worker package and fail fast if the image cannot satisfy the
# current SGLang runtime contract.
RUN pip install --no-cache-dir -e . && \
    echo "=== Verifying installation ===" && \
    python -c "import torch; print(f'PyTorch {torch.__version__}, CUDA: {torch.version.cuda}')" && \
    python -c "import transformers; print(f'Transformers {transformers.__version__}')" && \
    python -c "import ctypes; ctypes.CDLL('libnuma.so.1'); print('libnuma OK')" && \
    python -c "import sglang as sgl; print(f'SGLang {getattr(sgl, \"__version__\", \"unknown\")}')" && \
    python -c "from sglang.utils import async_stream_and_merge; print('SGLang imports OK')" && \
    python -c "from infera_worker.engines.sglang_engine import SGLangEngine; print('SGLangEngine OK')"

RUN groupadd --gid 10001 infera && \
    useradd --uid 10001 --gid 10001 --create-home --home-dir /home/infera --shell /usr/sbin/nologin infera && \
    mkdir -p /home/infera/.cache/huggingface/hub /home/infera/.cache/torch && \
    chown -R infera:infera /app /home/infera

ENV INFERA_ENGINE=sglang
ENV INFERA_HTTP_PORT=8081
ENV INFERA_GRPC_PORT=50051
ENV INFERA_LOG_LEVEL=INFO
ENV INFERA_LOG_FORMAT=json

# Use a user-owned cache location by default. Deployments can still override
# these paths when they intentionally mount a persistent writable volume.
ENV HOME=/home/infera
ENV XDG_CACHE_HOME=/home/infera/.cache
ENV HF_HOME=/home/infera/.cache/huggingface
ENV HUGGINGFACE_HUB_CACHE=/home/infera/.cache/huggingface/hub
ENV TRANSFORMERS_CACHE=/home/infera/.cache/huggingface/hub
ENV TORCH_HOME=/home/infera/.cache/torch

ENV INFERA_ROUTER_ADDRESS=""
ENV INFERA_PRELOAD_MODELS=""

EXPOSE 8081 50051

USER infera

HEALTHCHECK --interval=30s --timeout=10s --start-period=300s --retries=3 \
    CMD curl -f http://localhost:8081/health || exit 1

CMD ["python", "-m", "infera_worker.cli"]
